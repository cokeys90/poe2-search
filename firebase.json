{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "//": "⚠️ Firebase의 headers는 **요청 경로**로 매칭한다 — 실제로 서빙되는 파일이 아니다. 그래서 '**/index.html'만으로는 '/'나 '/en/' 요청에 안 걸린다(기본 max-age=3600이 붙어 배포 후 1시간 동안 옛 앱이 뜬다). 디렉터리 경로를 따로 적어야 한다.",
        "source": "/",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "//": "언어별 경로 (/en/ /ja/ /zh-tw/ …). *는 /를 넘지 않으므로 한 단계만 매칭된다",
        "source": "/*/",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "//": "index.html에 직접 접근하는 경우",
        "source": "**/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "//": "번들은 파일명에 해시가 붙으므로 오래 캐시해도 안전하다",
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
